---
type Props = {
  src: string;
  title: string;
};

const { src, title } = Astro.props;
---

<div class="video-embed" data-video-embed>
  <video src={src} title={title} preload="metadata" playsinline aria-describedby="intro-video-caption-note"></video>
  <button class="video-play" type="button" aria-label={`Play video: ${title}`}>
    <svg viewBox="0 0 24 24" aria-hidden="true">
      <path d="M8 5v14l11-7z" />
    </svg>
  </button>
  <p class="sr-only" id="intro-video-caption-note">
    Captions will be added when the final introduction video is available.
  </p>
</div>

<script>
  const embeds = document.querySelectorAll("[data-video-embed]");

  embeds.forEach((embed) => {
    if (!(embed instanceof HTMLElement)) return;

    const video = embed.querySelector("video");
    const playButton = embed.querySelector("button");

    playButton?.addEventListener("click", async () => {
      if (!(video instanceof HTMLVideoElement)) return;
      video.controls = true;
      embed.classList.add("is-playing");
      await video.play();
      video.focus();
    });
  });
</script>
