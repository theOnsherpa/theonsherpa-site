<canvas class="falling-prisms" data-falling-prisms aria-hidden="true"></canvas>

<script>
  const canvases = document.querySelectorAll("[data-falling-prisms]");

  canvases.forEach((canvas) => {
    if (!(canvas instanceof HTMLCanvasElement)) return;

    const context = canvas.getContext("2d");
    if (!context) return;

    type Point3 = { x: number; y: number; z: number };
    type Prism = {
      x: number;
      y: number;
      startY: number;
      bornAt: number;
      size: number;
      speed: number;
      yaw: number;
      pitch: number;
      roll: number;
      yawStart: number;
      pitchStart: number;
      rollStart: number;
      yawRate: number;
      pitchRate: number;
      rollRate: number;
      shape: "wide" | "tall" | "short";
    };

    const state = {
      width: 0,
      height: 0,
      dpr: 1,
      prisms: [] as Prism[],
    };

    const shapes: Record<Prism["shape"], Point3> = {
      wide: { x: 1.5, y: 0.38, z: 0.46 },
      tall: { x: 0.5, y: 0.52, z: 1.24 },
      short: { x: 1.1, y: 0.34, z: 0.42 },
    };

    const spawn = (y = -0.2, now = performance.now() / 1000) => {
      const names = Object.keys(shapes) as Prism["shape"][];
      const yaw = Math.random() * Math.PI * 2;
      const pitch = -0.5 + Math.random() * 1;
      const roll = Math.random() * Math.PI * 2;
      state.prisms.push({
        x: 0.5 + Math.random() * 0.46,
        y,
        startY: y,
        bornAt: now,
        size: 0.72 + Math.random() * 0.36,
        speed: 0.012 + Math.random() * 0.01,
        yaw,
        pitch,
        roll,
        yawStart: yaw,
        pitchStart: pitch,
        rollStart: roll,
        yawRate: -0.2 + Math.random() * 0.4,
        pitchRate: -0.12 + Math.random() * 0.24,
        rollRate: -0.16 + Math.random() * 0.32,
        shape: names[Math.floor(Math.random() * names.length)],
      });
    };

    const seedPrisms = () => {
      const count = state.width < 720 ? 9 : 15;
      const now = performance.now() / 1000;
      for (let i = 0; i < count; i += 1) {
        spawn(-0.18 + Math.random() * 1.34, now);
      }
    };

    const resize = () => {
      const rect = canvas.getBoundingClientRect();
      state.dpr = Math.min(window.devicePixelRatio || 1, 2);
      state.width = rect.width;
      state.height = rect.height;
      canvas.width = Math.floor(rect.width * state.dpr);
      canvas.height = Math.floor(rect.height * state.dpr);
      context.setTransform(state.dpr, 0, 0, state.dpr, 0, 0);
      if (state.prisms.length === 0) {
        seedPrisms();
      }
    };

    const rotatePoint = ({ x, y, z }: Point3, yaw: number, pitch: number, roll: number): Point3 => {
      const cy = Math.cos(yaw);
      const sy = Math.sin(yaw);
      const cp = Math.cos(pitch);
      const sp = Math.sin(pitch);
      const cr = Math.cos(roll);
      const sr = Math.sin(roll);
      const x1 = x * cy - y * sy;
      const y1 = x * sy + y * cy;
      const z1 = z;
      const x2 = x1 * cp + z1 * sp;
      const y2 = y1;
      const z2 = -x1 * sp + z1 * cp;
      return { x: x2, y: y2 * cr - z2 * sr, z: y2 * sr + z2 * cr };
    };

    const projectRotated = ({ x, y, z }: Point3, cx: number, cy: number, scale: number) => {
      return {
        x: cx + (x - y) * scale * 0.82,
        y: cy + (x + y) * scale * 0.46 - z * scale * 0.9,
      };
    };

    const updatePrism = (prism: Prism, now: number) => {
      const age = now - prism.bornAt;
      prism.y = prism.startY + prism.speed * age;
      prism.yaw = prism.yawStart + prism.yawRate * age;
      prism.pitch = prism.pitchStart + prism.pitchRate * age;
      prism.roll = prism.rollStart + prism.rollRate * age;
    };

    const drawPrism = (prism: Prism) => {
      const cx = state.width * prism.x;
      const cy = state.height * prism.y;
      const scale = Math.min(state.width, state.height) * 0.13 * prism.size;
      const size = shapes[prism.shape];
      const corners: Point3[] = [];

      [-1, 1].forEach((sx) => {
        [-1, 1].forEach((sy) => {
          [-1, 1].forEach((sz) => {
            corners.push({
              x: sx * size.x * 0.5,
              y: sy * size.y * 0.5,
              z: sz * size.z * 0.5,
            });
          });
        });
      });

      const rotated = corners.map((corner) => rotatePoint(corner, prism.yaw, prism.pitch, prism.roll));
      const p = rotated.map((corner) => projectRotated(corner, cx, cy, scale));
      const edgeIndexes = [
        [0, 1],
        [0, 2],
        [0, 4],
        [1, 3],
        [1, 5],
        [2, 3],
        [2, 6],
        [3, 7],
        [4, 5],
        [4, 6],
        [5, 7],
        [6, 7],
      ];
      const rearCorner = rotated.reduce(
        (rear, point, index) => {
          const depth = point.x + point.y + point.z;
          return depth < rear.depth ? { index, depth } : rear;
        },
        { index: 0, depth: Number.POSITIVE_INFINITY },
      );
      const hiddenEdges = new Set(
        edgeIndexes
          .filter(([a, b]) => a === rearCorner.index || b === rearCorner.index)
          .map(([a, b]) => `${a}-${b}`),
      );
      const edge = (a: number, b: number, alpha = 0.48, dashed = false) => {
        context.strokeStyle = `rgba(247, 248, 245, ${alpha})`;
        context.setLineDash(dashed ? [6, 8] : []);
        context.beginPath();
        context.moveTo(p[a].x, p[a].y);
        context.lineTo(p[b].x, p[b].y);
        context.stroke();
        context.setLineDash([]);
      };

      edgeIndexes.forEach(([a, b]) => {
        const key = `${a}-${b}`;
        if (hiddenEdges.has(key)) {
          edge(a, b, 0.16, true);
        }
      });

      edgeIndexes.forEach(([a, b]) => {
        const key = `${a}-${b}`;
        if (!hiddenEdges.has(key)) {
          edge(a, b);
        }
      });
    };

    const draw = (time = 0) => {
      const now = time / 1000;
      context.clearRect(0, 0, state.width, state.height);
      context.lineCap = "round";
      context.lineJoin = "round";
      context.lineWidth = 1.15;

      state.prisms.forEach((prism) => {
        updatePrism(prism, now);
        drawPrism(prism);
      });
      for (let i = state.prisms.length - 1; i >= 0; i -= 1) {
        if (state.prisms[i].y > 1.2) {
          state.prisms.splice(i, 1);
          spawn(-0.2, now);
        }
      }

      requestAnimationFrame(draw);
    };

    window.addEventListener("resize", resize);
    resize();
    draw();
  });
</script>
