---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Accessibility | The Onsherpa"
  description="Accessibility statement and feedback contact for The Onsherpa website."
>
  <section class="simple-page">
    <p class="eyebrow">Accessibility</p>
    <h1>Accessibility statement</h1>
    <p>
      The Onsherpa is working to make this website accessible and usable for as
      many people as possible. The site is designed with semantic structure,
      keyboard access, readable contrast, reduced-motion support, and responsive
      layouts in mind.
    </p>
    <p>
      If you have trouble accessing any part of this site, please get in touch
      through the contact page and describe the issue. I will use that feedback
      to improve the site.
    </p>
    <a class="button button-primary" href="/contact/">Contact The Onsherpa</a>
  </section>
</BaseLayout>
