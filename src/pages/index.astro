---
import BaseLayout from "../layouts/BaseLayout.astro";
import TrustedBy from "../components/TrustedBy.astro";
import VideoEmbed from "../components/VideoEmbed.astro";
---

<BaseLayout
  title="The Onsherpa | Peak Onshape productivity"
  description="Onshape consulting, migration, automation, and custom FeatureScript by Evan Reese."
>
  <section class="hero">
    <div class="hero-content">
      <div class="hero-copy-block">
        <p class="eyebrow">Onshape Coaching for Teams</p>
        <h1>
          Hi, I’m Evan Reese,
          <span>The Onsherpa</span>
        </h1>
        <p class="hero-copy">
          Your team's time in Onshape costs a lot more than Onshape itself. The
          Onsherpa guides you to peak performance, maximizing that valuable time.
        </p>
        <div class="hero-actions">
          <a class="button button-primary" href="/contact/">Book a free consultation now</a>
        </div>
      </div>
      <div class="hero-video">
        <VideoEmbed src="/video/The%20Onsherpa%20Introduction.mp4" title="The Onsherpa introduction" />
      </div>
    </div>
  </section>

  <section class="split-section">
    <div>
      <p class="section-kicker">When Onshape slows down</p>
      <h2>If you’re losing time and money on...</h2>
      <a class="button button-primary section-title-cta" href="/contact/">Book a free consultation now</a>
    </div>
    <div class="story-list problem-list">
      <p><span class="story-icon" aria-hidden="true">×</span><span class="story-copy">Making the switch from another CAD system</span></p>
      <p><span class="story-icon" aria-hidden="true">×</span><span class="story-copy">Slow models and spinning wheels</span></p>
      <p><span class="story-icon" aria-hidden="true">×</span><span class="story-copy">Clunky workarounds</span></p>
      <p><span class="story-icon" aria-hidden="true">×</span><span class="story-copy">Disorganized data</span></p>
      <p><span class="story-icon" aria-hidden="true">×</span><span class="story-copy">Lack of cohesive practices</span></p>
      <p><span class="story-icon" aria-hidden="true">×</span><span class="story-copy">Tedious repetitive work</span></p>
    </div>
  </section>

  <section class="outcome-band">
    <div>
      <p class="section-kicker">Guided improvement</p>
      <h2>The Onsherpa can help you...</h2>
      <a class="button button-primary section-title-cta" href="/contact/">Book a free consultation now</a>
    </div>
    <div class="story-list solution-list">
      <p><span class="story-icon" aria-hidden="true">✓</span><span class="story-copy">Migrate your people (not just your data) to Onshape <em>quickly</em></span></p>
      <p><span class="story-icon" aria-hidden="true">✓</span><span class="story-copy">Automate tedious tasks with Featurescript</span></p>
      <p><span class="story-icon" aria-hidden="true">✓</span><span class="story-copy">Find your unique best practices</span></p>
      <p><span class="story-icon" aria-hidden="true">✓</span><span class="story-copy">Demystify Onshape</span></p>
      <p><span class="story-icon" aria-hidden="true">✓</span><span class="story-copy">Ensure high quality CAD from the whole team</span></p>
      <p><span class="story-icon" aria-hidden="true">✓</span><span class="story-copy">Upskill your team</span></p>
    </div>
  </section>

  <section class="plan-section">
    <div class="plan-heading">
      <p class="section-kicker">Three simple steps</p>
      <h2>Getting started is easy</h2>
      <a class="button button-primary" href="/contact/">Book a free consultation now</a>
    </div>
    <div class="plan-steps">
      <article>
        <span>1</span>
        <div>
          <h3>Schedule a free consultation</h3>
          <p>We’ll assess your needs together.</p>
        </div>
      </article>
      <article>
        <span>2</span>
        <div>
          <h3>Get a custom plan</h3>
          <p>We’ll define success and map a path to it.</p>
        </div>
      </article>
      <article>
        <span>3</span>
        <div>
          <h3>Level you up</h3>
          <p>
            Whether it’s upskilling or automating, you’ll get more out of
            Onshape from here on out.
          </p>
        </div>
      </article>
    </div>
  </section>

  <TrustedBy />
</BaseLayout>
