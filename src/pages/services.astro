---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Services | The Onsherpa"
  description="Onshape migration, team standards, model performance, and custom FeatureScript services."
>
  <section class="page-hero compact">
    <p class="eyebrow">Services</p>
    <h1>Practical help for teams building in Onshape</h1>
    <p>
      Focused consulting for teams that want to move faster, build cleaner
      models, and turn repeated CAD friction into repeatable systems.
    </p>
  </section>

  <section class="service-stack">
    <article>
      <span>Migration</span>
      <h2>Onshape adoption and migration</h2>
      <p>
        Migrate your people, practices, and modeling habits into Onshape with
        less drag and more confidence.
      </p>
    </article>
    <article>
      <span>Automation</span>
      <h2>Custom FeatureScript</h2>
      <p>
        Build custom features that compress tedious modeling steps into tools
        your team can reuse.
      </p>
    </article>
    <article>
      <span>Systems</span>
      <h2>Workflow and standards</h2>
      <p>
        Establish cohesive practices around data organization, modeling
        conventions, performance, and team collaboration.
      </p>
    </article>
  </section>
</BaseLayout>
